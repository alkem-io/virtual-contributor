# Core
PLUGIN_TYPE=generic
LOG_LEVEL=INFO

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_USER=alkemio-admin
RABBITMQ_PASSWORD=alkemio!
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=virtual-contributor-engine-generic
RABBITMQ_RESULT_QUEUE=virtual-contributor-invoke-engine-result
RABBITMQ_EVENT_BUS_EXCHANGE=event-bus
RABBITMQ_RESULT_ROUTING_KEY=invoke-engine-result

# ChromaDB
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8765
VECTOR_DB_CREDENTIALS=

# LLM — provider-agnostic configuration
# Supported providers: mistral, openai, anthropic
LLM_PROVIDER=mistral
LLM_API_KEY=
# Default: mistral-large-latest / gpt-4o / claude-sonnet-4-6
LLM_MODEL=
# Set for local models (e.g., http://localhost:8000/v1)
LLM_BASE_URL=
# 0.0–2.0 (optional)
LLM_TEMPERATURE=
# >0 (optional)
LLM_MAX_TOKENS=
# 0.0–1.0 (optional)
LLM_TOP_P=
# Seconds
LLM_TIMEOUT=120

# LLM — backward compatibility (still works for Mistral)
MISTRAL_API_KEY=
MISTRAL_SMALL_MODEL_NAME=mistral-small-latest

# LLM — per-plugin overrides (optional, prefix with PLUGIN_NAME_)
# Example: GUIDANCE_LLM_PROVIDER=openai, GUIDANCE_LLM_API_KEY=sk-...

# Summarization LLM — optional separate model for document/BoK summarization
# All three required to activate; if any missing, main LLM is used
SUMMARIZE_LLM_PROVIDER=
SUMMARIZE_LLM_MODEL=
SUMMARIZE_LLM_API_KEY=
# Optional: base URL override for summarization (e.g., different port for a local model)
SUMMARIZE_LLM_BASE_URL=
# Optional tuning (defaults: temperature=0.3 when active, timeout=LLM_TIMEOUT)
SUMMARIZE_LLM_TEMPERATURE=
SUMMARIZE_LLM_TIMEOUT=

# BoK LLM — optional separate model for body-of-knowledge summarization
# Needs large context window. Falls back to summarize LLM, then main LLM.
BOK_LLM_PROVIDER=
BOK_LLM_MODEL=
BOK_LLM_API_KEY=
BOK_LLM_BASE_URL=
BOK_LLM_TEMPERATURE=
BOK_LLM_TIMEOUT=

# Per-plugin retrieval parameters
EXPERT_N_RESULTS=5
EXPERT_MIN_SCORE=0.3
GUIDANCE_N_RESULTS=5
GUIDANCE_MIN_SCORE=0.3

# Context budget — max chars of retrieved context passed to LLM
MAX_CONTEXT_CHARS=20000

# Summarization threshold — docs with >= this many chunks get summarized
SUMMARY_CHUNK_THRESHOLD=4

# Embeddings (expert, guidance, ingest plugins)
EMBEDDINGS_API_KEY=
EMBEDDINGS_ENDPOINT=https://api.scaleway.ai/v1
EMBEDDINGS_MODEL_NAME=qwen3-embedding-8b

# Ingest pipeline
CHUNK_SIZE=2000
CHUNK_OVERLAP=400
BATCH_SIZE=20
SUMMARY_LENGTH=10000

# Health server
HEALTH_PORT=8080

# Ingest Space only
API_ENDPOINT_PRIVATE_GRAPHQL=http://localhost:3000/api/private/non-interactive/graphql
AUTH_ORY_KRATOS_PUBLIC_BASE_URL=http://localhost:3000/ory/kratos/public
AUTH_ADMIN_EMAIL=master-admin@alkem.io
AUTH_ADMIN_PASSWORD=master-password

# OpenAI Assistant only
RUN_POLL_TIMEOUT_SECONDS=300

# Ingest Website only
PROCESS_PAGES_LIMIT=20
